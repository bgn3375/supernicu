// src/hooks/useDelete{Feature}.ts
// Bare useMutation — no toasts, no invalidation, no errorService inside the hook.
// Page owns UX: onSuccess/onError passed to mutate().

import { useMutation } from '@tanstack/react-query';
import { invoicesService } from '@/api/invoices/invoicesService';

export function useDeleteInvoice() {
  return useMutation({ mutationFn: (id: number) => invoicesService.deleteInvoice(id) });
}
