import type { ExtendedPagedFilter, PagedSearchResult } from './pagination';

export type InvoiceStatus = 'draft' | 'sent' | 'paid' | 'overdue' | 'cancelled';

export interface Invoice {
  Id: number;
  Number: string;
  CustomerName: string;
  Status: InvoiceStatus;
  TotalAmount: number;
  IssuedAt: string;
  DueAt: string;
}

export interface InvoiceFilters {
  Status?: InvoiceStatus;
}

export type InvoicePagedFilter = ExtendedPagedFilter<InvoiceFilters>;
export type InvoicePagedResult = PagedSearchResult<Invoice>;
