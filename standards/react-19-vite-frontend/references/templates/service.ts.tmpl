// src/api/{feature}/{feature}Service.ts
// Substitute: invoices → {feature}, Invoice → {Feature}.
// All network calls route through httpClient — never raw fetch.

import { httpClient } from '@/api/core/httpClient';
import type { Invoice, InvoicePagedFilter, InvoicePagedResult } from '@/types';

export const invoicesService = {
  getInvoices: (filter: InvoicePagedFilter): Promise<InvoicePagedResult> =>
    httpClient.post<InvoicePagedResult>('/api/invoices/list', filter),

  getInvoice: (id: number): Promise<Invoice> =>
    httpClient.get<Invoice>(`/api/invoices/${id}`),

  deleteInvoice: (id: number): Promise<void> =>
    httpClient.delete<void>(`/api/invoices/${id}`),
};
